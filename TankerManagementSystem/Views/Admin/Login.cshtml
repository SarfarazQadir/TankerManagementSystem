@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>BillBook Admin Login</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

    <!-- Required CSS -->
    <link rel="stylesheet" href="~/css/app.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/custom.css" />
    <link rel="shortcut icon" href="~/img/flyeasy.png" />

    <!-- Font Awesome Icons -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
    <style>
        :root {
            --primary-color: #3b82f6;
            --primary-hover: #2563eb;
            --input-bg: #f3f4f6;
            --text-dark: #1f2937;
            --text-secondary: #4b5563;
            --card-shadow: rgba(0, 0, 0, 0.1);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            font-family: 'Inter', sans-serif;
            background-color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
            padding: 40px 30px;
            background-color: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            box-shadow: 0 10px 30px var(--card-shadow);
        }

        .login-logo {
            text-align: center;
            margin-bottom: -32px;
            margin-top: -50px !important;
        }

            .login-logo img {
                max-width: 180px;
                height: auto;
            }

        .login-subtitle {
            font-size: 14px;
            color: var(--text-secondary);
            text-align: center;
            margin-bottom: 30px;
        }

        .form-group {
            position: relative;
            margin-bottom: 25px;
        }

        .form-control {
            width: 100%;
            padding: 12px 40px 12px 15px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            background-color: var(--input-bg);
            color: var(--text-dark);
            font-size: 15px;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

            .form-control::placeholder {
                color: #9ca3af;
            }

        .form-group i {
            position: absolute;
            top: 70%;
            right: 15px;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 18px;
            cursor: pointer;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.3);
            background-color: #ffffff;
        }

        .btn-primary {
            width: 100%;
            padding: 14px;
            font-size: 16px;
            font-weight: 600;
            color: #ffffff;
            background-color: var(--primary-color);
            border: none;
            border-radius: 8px;
            transition: background-color 0.3s, box-shadow 0.3s;
        }

            .btn-primary:hover {
                background-color: var(--primary-hover);
                box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
            }

        .custom-checkbox .custom-control-label {
            color: var(--text-dark);
        }

        .text-small a {
            color: var(--primary-color);
            text-decoration: none;
            font-size: 0.9em;
        }

            .text-small a:hover {
                text-decoration: underline;
            }

        .swal2-popup {
            font-size: 16px !important;
        }
    </style>
</head>

<body>

    <!-- Sweet Alert -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@10"></script>

    @* Alert Messages *@
    @{
        if (TempData["login_failed_message"] != null)
        {
            <script>
                Swal.fire({
                    title: '@TempData["login_failed_message"]',
                    text: 'Please try again',
                    icon: 'error'
                });
            </script>
        }
        if (TempData["logout_message"] != null)
        {
            <script>
                Swal.fire({
                    title: '@TempData["logout_message"]',
                    text: 'You have been logged out',
                    icon: 'success'
                });
            </script>
        }
    }

    <div class="login-container">
        <div class="login-logo">
            <img src="~/img/flyeasy.png" alt="FlyEasy Logo" />
        </div>
        <div style="margin-top: 10px;" class="login-subtitle">Login to manage your account & bills</div>

        <form method="POST" action="" class="needs-validation" novalidate="">
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="adminEmail" id="email" class="form-control" placeholder="Enter your email" required />
                <i class="fas fa-envelope"></i>
                <div class="invalid-feedback">Please fill in your email</div>
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" id="password" name="adminPassword" class="form-control" placeholder="Enter your password" required />
                <i class="fas fa-eye toggle-password" id="togglePassword"></i>
                <div class="invalid-feedback">Please fill in your password</div>
            </div>

            <div class="form-group d-flex justify-content-between align-items-center">
                <div class="custom-control custom-checkbox">
                    <input type="checkbox" name="remember" class="custom-control-input" id="remember">
                    <label class="custom-control-label" for="remember">Remember Me</label>
                </div>
            </div>

            <div class="form-group">
                <input type="submit" style="background-color:#86608E!important;" class="btn btn-primary" value="Login" />
            </div>
        </form>
    </div>

    <!-- Scripts -->
    <script src="~/js/app.min.js"></script>
    <script src="~/js/scripts.js"></script>
    <script src="~/js/custom.js"></script>

    <!-- Custom JS for Password Toggle and Remember Me -->
    <script>
        // Password Toggle
        document.getElementById("togglePassword").addEventListener("click", function () {
            const passwordInput = document.getElementById("password");
            const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
            passwordInput.setAttribute("type", type);

            this.classList.toggle("fa-eye");
            this.classList.toggle("fa-eye-slash");
        });

        // Remember Me - LocalStorage
        document.addEventListener("DOMContentLoaded", function () {
            const emailInput = document.getElementById("email");
            const passwordInput = document.getElementById("password");
            const rememberCheckbox = document.getElementById("remember");

            // Load saved values
            if (localStorage.getItem("rememberMe") === "true") {
                emailInput.value = localStorage.getItem("adminEmail") || "";
                passwordInput.value = localStorage.getItem("adminPassword") || "";
                rememberCheckbox.checked = true;
            }

            // On form submit
            document.querySelector("form").addEventListener("submit", function () {
                if (rememberCheckbox.checked) {
                    localStorage.setItem("adminEmail", emailInput.value);
                    localStorage.setItem("adminPassword", passwordInput.value);
                    localStorage.setItem("rememberMe", "true");
                } else {
                    localStorage.removeItem("adminEmail");
                    localStorage.removeItem("adminPassword");
                    localStorage.setItem("rememberMe", "false");
                }
            });
        });
    </script>
</body>
</html>

