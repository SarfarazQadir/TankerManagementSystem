
@{
    ViewData["Title"] = "AddEntry";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<section class="section">
    <div class="card">
        <div class="card-header"><h4>Add Trip</h4></div>

        <div class="card-body">
            <form method="post" asp-action="AddEntry">

                <div class="form-group">
                    <label>Load Date</label>
                    <input type="date" name="LoadDate" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Select Tanker</label>
                    <select name="TankerId" class="form-control">
                        <option value="">-- Select Tanker --</option>
                        @foreach (var t in ViewBag.Tankers)
                        {
                            <option value="@t.Id">@t.TankerNo</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Advance Cash</label>
                    <input type="number" name="AdvanceCash" class="form-control" />
                </div>

                <div class="form-group">
                    <label>From Location</label>
                    <input type="text" name="FromLocation" class="form-control" />
                </div>

                <div class="form-group">
                    <label>To Location</label>
                    <input type="text" name="ToLocation" class="form-control" />
                </div>

                <div class="text-center">
                    <button class="btn btn-primary">Add Trip</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
                </div>

            </form>
        </div>
    </div>
</section>