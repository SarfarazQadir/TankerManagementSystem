@model TankerManagementSystem.Models.TripEntry

@{
    ViewData["Title"] = "EditEntry";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}


<section class="section">
    <div class="card">
        <div class="card-header"><h4>Edit Trip</h4></div>

        <div class="card-body">
            <form method="post" asp-action="EditEntry">

                <input type="hidden" asp-for="Id" />

                <div class="form-group">
                    <label>Load Date</label>
                    <input asp-for="LoadDate" type="date" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Select Tanker</label>
                    <select asp-for="TankerId" class="form-control">
                        @foreach (var t in ViewBag.Tankers)
                        {
                            <option value="@t.Id" selected="@(t.Id == Model.TankerId)">
                                @t.TankerNo
                            </option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Advance Cash</label>
                    <input asp-for="AdvanceCash" class="form-control" />
                </div>

                <div class="form-group">
                    <label>From Location</label>
                    <input asp-for="FromLocation" class="form-control" />
                </div>

                <div class="form-group">
                    <label>To Location</label>
                    <input asp-for="ToLocation" class="form-control" />
                </div>

                <div class="text-center">
                    <button class="btn btn-primary">Update</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Back</a>
                </div>

            </form>
        </div>
    </div>
</section>