@model IEnumerable<TankerManagementSystem.Models.User>

@{
    ViewData["Title"] = "FetchUsers";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}


@if (TempData["success"] != null)
{
    <script>
        Swal.fire({
            title: '@TempData["success"]',
            icon: 'success'
        });
    </script>
}

<section class="section">
    <div class="section-body">

        <a href="@Url.Action("CreatUser")" class="btn btn-primary">Add User</a>

        <br /><br />

        <div class="card">
            <div class="card-header">
                <h4>User Details</h4>
            </div>

            <div class="card-body">
                <div class="table-responsive">

                    <table class="table table-striped table-bordered table-hover" id="myTable">
                        <thead>
                            <tr>
                                <th>S.No</th>
                                <th>Id</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Username</th>
                                <th>Created At</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                int serial = 1;
                            }

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@serial</td>
                                    <td>@item.Id</td>
                                    <td>@item.FullName</td>
                                    <td>@item.Email</td>
                                    <td>@item.UserName</td>
                                    <td>@item.CreatedAt.ToString("dd/MMM/yyy hh:tt")</td>

                                    <td>
                                        <div class="dropdown">
                                            <a href="#" data-toggle="dropdown" class="btn btn-warning dropdown-toggle">
                                                Options
                                            </a>

                                            <div class="dropdown-menu">
                                                <a href="@Url.Action("EditUser", new { id = item.Id })" class="dropdown-item has-icon">
                                                    <i class="far fa-edit"></i> Edit
                                                </a>

                                                <a href="javascript:void(0);" onclick="confirmDelete(@item.Id)" class="dropdown-item has-icon text-danger">
                                                    <i class="far fa-trash-alt"></i> Delete
                                                </a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                                serial++;
                            }

                        </tbody>
                    </table>

                </div>
            </div>
        </div>

    </div>
</section>

<script>
    function confirmDelete(id) {
        Swal.fire({
            title: "Are you sure?",
            text: "This user will be deleted permanently!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#3085d6",
            confirmButtonText: "Yes, delete it!"
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = '/User/DeleteUser/' + id;
            }
        });
    }
</script>