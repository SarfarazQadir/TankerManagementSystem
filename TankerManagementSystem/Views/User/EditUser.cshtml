@model TankerManagementSystem.Models.User

@{
    ViewData["Title"] = "EditUser";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}



<section class="section">
    <div class="section-body">
        <div class="card">
            <div class="card-header">
                <h4>Edit User</h4>
            </div>

            <div class="card-body">
                <form method="post" asp-action="EditUser">

                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label>Full Name</label>
                        <input asp-for="FullName" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>Username</label>
                        <input asp-for="UserName" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label>New Password (optional)</label>
                        <input type="password" name="PasswordHash" class="form-control" />
                    </div>

                    <hr />

                    <h5 class="mb-3">Module Permissions</h5>

                 @*    @foreach (var module in ViewBag.Modules)
                    {
                        var perm = ((List<TankerManagementSystem.Models.UserPermission>)ViewBag.Permissions)
                        .FirstOrDefault(x => x.ModuleId == module.Id);

                        <div class="border rounded p-3 mb-3">
                            <strong>@module.Name</strong>

                            <input type="hidden" name="permissions[].ModuleId" value="@module.Id" />

                            <div class="mt-2">

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[].CanView" value="true"
                                           @(perm?.CanView == true ? "checked" : "") /> View
                                </label>

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[].CanAdd" value="true"
                                           @(perm?.CanAdd == true ? "checked" : "") /> Add
                                </label>

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[].CanEdit" value="true"
                                           @(perm?.CanEdit == true ? "checked" : "") /> Edit
                                </label>

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[].CanDelete" value="true"
                                           @(perm?.CanDelete == true ? "checked" : "") /> Delete
                                </label>

                            </div>
                        </div>
                    }
 *@

                    @for (int i = 0; i < ViewBag.Modules.Count; i++)
                    {
                        var module = ViewBag.Modules[i];
                        var perm = ((List<TankerManagementSystem.Models.UserPermission>)ViewBag.Permissions)
                        .FirstOrDefault(x => x.ModuleId == module.Id);

                        <div class="border rounded p-3 mb-3">
                            <strong>@module.Name</strong>

                            <input type="hidden" name="permissions[@i].ModuleId" value="@module.Id" />

                            <div class="mt-2">

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[@i].CanView" value="true"
                                           @(perm?.CanView == true ? "checked" : "") /> View
                                </label>

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[@i].CanAdd" value="true"
                                           @(perm?.CanAdd == true ? "checked" : "") /> Add
                                </label>

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[@i].CanEdit" value="true"
                                           @(perm?.CanEdit == true ? "checked" : "") /> Edit
                                </label>

                                <label class="mr-3">
                                    <input type="checkbox" name="permissions[@i].CanDelete" value="true"
                                           @(perm?.CanDelete == true ? "checked" : "") /> Delete
                                </label>

                            </div>
                        </div>
                    }
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary">Update User</button>
                        <a href="@Url.Action("FetchUsers")" class="btn btn-secondary">Back</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</section>