@model TankerManagementSystem.Models.User

@{
    ViewData["Title"] = "CreatUser";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}



<section class="section">
    <div class="section-body">
        <div class="card">
            <div class="card-header">
                <h4>Create User</h4>
            </div>

            <div class="card-body">

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }

                <form method="post" asp-action="CreatUser" onsubmit="return validatePassword()">

                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="FullName" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="Email" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" name="UserName" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" id="password" name="PasswordHash" class="form-control" required />
                        <small class="text-muted">
                            Must be 8+ characters, include 1 uppercase, 1 number, and 1 special character.
                        </small>
                    </div>

                    <div class="text-center mt-4">
                        <button type="submit" class="btn btn-primary">Create User</button>
                        <a href="@Url.Action("FetchUsers")" class="btn btn-secondary">Back</a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</section>

<script>
    function validatePassword() {
        var pass = document.getElementById("password").value;

        var regex = /^(?=.*[A-Z])(?=.*[0-9])(?=.*[@@!#$%^&*]).{8,}$/;

        if (!regex.test(pass)) {
            alert("Password must be 8+ chars, 1 uppercase, 1 number, 1 special char");
            return false;
        }
        return true;
    }
</script>