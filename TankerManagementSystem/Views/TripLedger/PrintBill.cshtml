@* @model TankerManagementSystem.Models.TripLedger
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trip Ledger - @Model.TripEntryId</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f4f4;
            color: #333;
            margin: 0;
            padding: 20px;
        }

        .bill-card {
            background: #fff;
            max-width: 850px;
            margin: 0 auto;
            padding: 40px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
            border-radius: 8px;
        }

        /* Header Section */
        .header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #eee;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .logo-section img {
            max-height: 80px; /* Adjust size as needed */
            width: auto;
        }

        .company-info h2 {
            margin: 0;
            color: #1a2a6c;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .company-info p {
            margin: 5px 0 0;
            font-size: 0.9em;
            color: #666;
        }

        /* Info Grid */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .info-box {
            background: #f9f9f9;
            padding: 15px;
            border-radius: 5px;
        }

            .info-box p {
                margin: 5px 0;
                font-size: 0.95em;
            }

        /* Table Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            margin: 20px 0;
        }

        th {
            background-color: #f8f9fa;
            color: #333;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85em;
            border-bottom: 2px solid #dee2e6;
            padding: 12px;
            text-align: left;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #eee;
            font-size: 0.95em;
        }

        .text-right {
            text-align: right;
        }

        .font-bold {
            font-weight: bold;
        }

        /* Summary Section */
        .summary-wrapper {
            display: flex;
            justify-content: flex-end;
            margin-top: 20px;
        }

        .summary-table {
            width: 300px;
        }

            .summary-table tr td:first-child {
                color: #666;
            }

        .grand-total {
            background-color: #1a2a6c;
            color: white;
            border-radius: 4px;
        }

            .grand-total td {
                border: none;
                padding: 15px;
                font-size: 1.2em;
            }

        .remarks {
            margin-top: 30px;
            font-size: 0.9em;
            border-left: 4px solid #1a2a6c;
            padding-left: 15px;
            font-style: italic;
            color: #555;
        }

        /* Print Button */
        .no-print {
            text-align: center;
            margin-bottom: 20px;
        }

        .btn-print {
            background: #1a2a6c;
            color: white;
            padding: 10px 25px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        @@media print {
            .no-print {
                display: none;
            }

            body {
                background: white;
                padding: 0;
            }

            .bill-card {
                box-shadow: none;
                border: none;
                max-width: 100%;
            }
        }
    </style>
</head>
<body>

    <div class="no-print">
        <button class="btn-print" onclick="window.print()">Download / Print Bill</button>
    </div>

    <div class="bill-card">
        <!-- Header -->
        <div class="header-flex">
            <div class="logo-section">
                <!-- Replace with your actual logo path -->
                <img src="~/img/flyeasy.png" alt="Company Logo" onerror="this.src='https://via.placeholder.com/150x80?text=MALIK+BROS'">
            </div>
            <div class="company-info text-right">
                <h2>MALIK AND BROTHERS</h2>
                <p>Date: @Model.TripDate.ToString("dd MMM, yyyy")</p>
                <p>Invoice #: @Model.TripEntryId</p>
            </div>
        </div>

        <!-- Details Grid -->
        <div class="info-grid">
            <div class="info-box">
                <p><strong>Tanker No:</strong> @Model.TripEntryFk?.TankerFk?.TankerNo</p>
                <p><strong>Product:</strong> @Model.Product?.ProductName</p>
                <p><strong>Token No:</strong> @Model.TokenNo</p>
            </div>
            <div class="info-box">
                <p><strong>Route:</strong></p>
                <p>@Model.TripEntryFk?.FromLocation <span style="color:#1a2a6c">→</span> @Model.TripEntryFk?.ToLocation</p>
            </div>
        </div>

        <!-- Calculations Table -->
        <h4>Bill Breakdown</h4>
        <table>
            <thead>
                <tr>
                    <th>Description</th>
                    <th class="text-right">Amount</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Total Freight</td>
                    <td class="text-right">@Model.Freight.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Advance Cash</td>
                    <td class="text-right">- @Model.AdvanceCash.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Shortage Deductions</td>
                    <td class="text-right">- @Model.Shortage.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Commission</td>
                    <td class="text-right">- @Model.Commission.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Munshiana</td>
                    <td class="text-right">- @Model.Munshiana.ToString("N2")</td>
                </tr>
                <tr>
                    <td>Previous Paid / Balance</td>
                    <td class="text-right">- @Model.PreviousBalance</td>
                </tr>
            </tbody>
        </table>

        <!-- Other Expenses -->
        @if (Model.Expenses != null && Model.Expenses.Any())
        {
            <h4>Other Advances & Expenses</h4>
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Detail</th>
                        <th class="text-right">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var exp in Model.Expenses)
                    {
                        <tr>
                            <td>@exp.CreatedAt.ToShortDateString()</td>
                            <td>@exp.ExpenseName</td>
                            <td class="text-right">@exp.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <!-- Summary -->
        <div class="summary-wrapper">
            <table class="summary-table">
                <tr>
                    <td class="padding-top">Other Expenses Total:</td>
                    <td class="text-right">@Model.Expenses.Sum(x => x.Amount).ToString("N2")</td>
                </tr>
                <tr class="grand-total">
                    <td class="font-bold">Net Balance:</td>
                    <td class="text-right font-bold">@Model.GrandTotal.ToString("N2")</td>
                </tr>
            </table>
        </div>

        @if (!string.IsNullOrEmpty(Model.Remarks))
        {
            <div class="remarks">
                <strong>Remarks:</strong> @Model.Remarks
            </div>
        }

        <div style="margin-top: 50px; border-top: 1px solid #eee; padding-top: 10px; font-size: 0.8em; color: #999; text-align: center;">
            This is a computer generated document.
        </div>
    </div>

</body>
</html> *@


@* @model TankerManagementSystem.Models.TripLedger
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Trip Ledger - @Model.TripEntryId</title>
    <style>
        :root {
            --primary-color: #86608E;
            --expense-red: #d9534f;
            --bg-light: #fdfafb;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #f0f0f0;
            color: #333;
            margin: 0;
            padding: 40px 20px;
        }

        .bill-card {
            background: #fff;
            max-width: 800px;
            margin: 0 auto;
            padding: 50px;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            position: relative;
            border-top: 8px solid var(--primary-color);
        }

        /* Header */
        .header-flex {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
        }

        .company-info h2 {
            margin: 0;
            color: var(--primary-color);
            font-size: 28px;
            letter-spacing: 1px;
        }

        .company-info p {
            margin: 5px 0;
            color: #777;
            font-size: 14px;
        }

        /* Stats Grid */
        .details-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }

        .detail-item {
            border: 1px solid #eee;
            padding: 12px;
            border-radius: 8px;
            text-align: center;
        }

            .detail-item label {
                display: block;
                font-size: 11px;
                text-transform: uppercase;
                color: #999;
                margin-bottom: 5px;
            }

            .detail-item span {
                font-weight: 600;
                color: #444;
            }

        /* Table Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th {
            text-align: left;
            padding: 12px 15px;
            font-size: 13px;
            color: var(--primary-color);
            border-bottom: 2px solid #f0f0f0;
            text-transform: uppercase;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid #f9f9f9;
            font-size: 15px;
        }

        /* Expense Specific Styling */
        .expense-row td {
            color: var(--expense-red);
            font-weight: 500;
        }

        .text-right {
            text-align: right;
        }

        /* Summary Section */
        .summary-container {
            margin-top: 30px;
            display: flex;
            justify-content: flex-end;
        }

        .summary-box {
            width: 320px;
            background: var(--bg-light);
            padding: 20px;
            border-radius: 8px;
        }

        .summary-line {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .total-line {
            border-top: 2px solid var(--primary-color);
            margin-top: 15px;
            padding-top: 15px;
            font-size: 20px;
            font-weight: bold;
            color: var(--primary-color);
        }

        /* Print Button */
        .no-print {
            text-align: center;
            margin-bottom: 30px;
        }

        .btn-print {
            background: var(--primary-color);
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 16px;
            transition: opacity 0.2s;
        }

            .btn-print:hover {
                opacity: 0.9;
            }

        @@media print {
            body {
                background: white;
                padding: 0;
            }

            .bill-card {
                box-shadow: none;
                border: none;
                width: 100%;
                max-width: 100%;
                padding: 20px;
            }

            .no-print {
                display: none;
            }

            .detail-item {
                border: 1px solid #ddd;
            }
        }
    </style>
</head>
<body>

    <div class="no-print">
        <button class="btn-print" onclick="window.print()">Print Receipt</button>
    </div>

    <div class="bill-card">
        <!-- Logo & Header -->
        <div class="header-flex">
            <div class="logo-area">
                <img src="~/img/flyeasy.png" alt="Logo" style="height: 70px;" onerror="this.src='https://via.placeholder.com/150x70?text=MALIK+BROS&bg=86608E&fg=fff'">
            </div>
            <div class="company-info text-right">
                <h2>MALIK AND BROTHERS</h2>
                <p>Trip Date: @Model.TripDate.ToString("dd MMM yyyy")</p>
                <p><strong>Bill ID: #@Model.TripEntryId</strong></p>
            </div>
        </div>

        <!-- Details -->
        <div class="details-grid">
            <div class="detail-item">
                <label>Tanker Number</label>
                <span>@Model.TripEntryFk?.TankerFk?.TankerNo</span>
            </div>
            <div class="detail-item">
                <label>Product</label>
                <span>@Model.Product?.ProductName</span>
            </div>
            <div class="detail-item">
                <label>Token / Route</label>
                <span>@Model.TokenNo | @Model.TripEntryFk?.ToLocation</span>
            </div>
        </div>

        <!-- Main Items -->
        <table>
            <thead>
                <tr>
                    <th>Description</th>
                    <th class="text-right">Amount (PKR)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Total Freight (Income)</td>
                    <td class="text-right">@Math.Floor(Model.Freight)</td>
                </tr>

                <!-- Expenses / Deductions in Red -->
                <tr class="expense-row">
                    <td>Advance Cash</td>
                    <td class="text-right">- @Math.Floor(Model.AdvanceCash)</td>
                </tr>
                <tr class="expense-row">
                    <td>Shortage Deductions</td>
                    <td class="text-right">- @Math.Floor(Model.Shortage)</td>
                </tr>
                <tr class="expense-row">
                    <td>Commission</td>
                    <td class="text-right">- @Math.Floor(Model.Commission)</td>
                </tr>
                <tr class="expense-row">
                    <td>Munshiana</td>
                    <td class="text-right">- @Math.Floor(Model.Munshiana)</td>
                </tr>
                <tr class="expense-row">
                    <td>Previous Paid / Balance</td>
                    <td class="text-right">- @Math.Floor(Model.PreviousBalance.Value)</td>
                </tr>

                @foreach (var exp in Model.Expenses)
                {
                    <tr class="expense-row">
                        <td>@exp.ExpenseName</td>
                        <td class="text-right">- @Math.Floor(exp.Amount)</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- Summary -->
        <div class="summary-container">
            <div class="summary-box">
                <div class="summary-line">
                    <span>Subtotal Expenses:</span>
                    <span style="color: var(--expense-red)">
                        @{
                            var totalExp = Model.AdvanceCash + Model.Shortage + Model.Commission +
                            Model.Munshiana + Model.PreviousBalance + Model.Expenses.Sum(x => x.Amount);
                            @Math.Floor(totalExp.Value)
                        }
                    </span>
                </div>
                <div class="summary-line total-line">
                    <span>Net Balance:</span>
                    <span>@Math.Floor(Model.GrandTotal)</span>
                </div>
            </div>
        </div>

        <div style="margin-top: 40px; color: #999; font-size: 12px;">
            <strong>Remarks:</strong> @(string.IsNullOrEmpty(Model.Remarks) ? "N/A" : Model.Remarks)
        </div>

        <div style="text-align: center; margin-top: 50px; border-top: 1px solid #eee; padding-top: 10px; font-size: 11px; color: #bbb;">
            Thank you for your business. This is a computer-generated document.
        </div>
    </div>

</body>
</html> *@



